// AI Receptionist Platform — Multi-Tenant SaaS schema
// SQLite-compatible (no enums, no native arrays)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────
// Plans & Billing
// ────────────────────────────────────────────────────────────
model Plan {
  id              String   @id @default(cuid())
  code            String   @unique // starter | growth | business | enterprise
  name            String
  description     String
  priceMonthly    Int      // price in Tomans (integer)
  messageLimit    Int      // monthly message quota
  conversationLimit Int
  voiceMinutes    Int
  tokenLimit      Int      // monthly token quota
  featuresJson    String   @default("[]") // JSON array of feature strings
  popular         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenants       Tenant[]
  subscriptions Subscription[]
  invoices      Invoice[]
}

// ────────────────────────────────────────────────────────────
// Tenant (each business = independent workspace)
// ────────────────────────────────────────────────────────────
model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique // subdomain / marketplace path
  name            String
  businessType    String   // store | restaurant | doctor | clinic | lawyer | travel | hotel | academy | realestate | other
  description     String   @default("")
  website         String   @default("")
  instagram       String   @default("")
  whatsapp        String   @default("")
  phone           String   @default("")
  address         String   @default("")
  logoUrl         String   @default("")
  accentColor     String   @default("#10b981") // brand accent
  category        String   @default("service") // marketplace category
  planId          String?
  status          String   @default("active") // active | suspended | trial
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  plan            Plan?    @relation(fields: [planId], references: [id])
  users           User[]
  agent           Agent?
  knowledge       KnowledgeItem[]
  conversations   Conversation[]
  leads           Lead[]
  bookings        Booking[]
  subscription    Subscription?
  invoices        Invoice[]
  referral        Referral?
  tokenLogs       TokenUsageLog[]
  internalLeads   InternalLead[]

  @@index([businessType])
  @@index([category])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Users (global, role-scoped per tenant)
// ────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String   @default("") // demo only — plaintext-ish
  role          String   @default("business_owner") // super_admin | business_owner | operator | end_user
  tenantId      String?
  avatarUrl     String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[] @relation("OperatorConversations")

  @@index([tenantId])
  @@index([role])
}

// ────────────────────────────────────────────────────────────
// AI Agent (per tenant)
// ────────────────────────────────────────────────────────────
model Agent {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  name               String   @default("منشی هوشمند")
  systemPrompt       String   @default("")
  model              String   @default("glm-4.6")
  temperature        Float    @default(0.4)
  confidenceThreshold Float   @default(0.55)
  greetingMessage    String   @default("سلام! من منشی هوشمند کسب‌وکار شما هستم. چطور می‌توانم کمک کنم؟")
  channelsJson       String   @default("[\"website\",\"widget\"]") // website | widget | instagram | whatsapp | voice
  voiceEnabled       Boolean  @default(false)
  humanHandoff       Boolean  @default(true)
  growthLoop         Boolean  @default(true)
  aiProviderId       String?  // null = use platform default (z-ai-web-dev-sdk)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aiProvider         AiProvider? @relation(fields: [aiProviderId], references: [id], onDelete: SetNull)

  @@index([tenantId])
}

// ────────────────────────────────────────────────────────────
// AI Provider configs — connect your own OpenAI / Anthropic / Gemini / custom endpoint
// ────────────────────────────────────────────────────────────
model AiProvider {
  id          String   @id @default(cuid())
  tenantId    String   // owner tenant (platform default if matches a flagged tenant)
  name        String   // display name, e.g. "OpenAI تولیدی"
  type        String   // zai | openai | anthropic | gemini | custom
  apiKey      String   // secret (stored; in production would be encrypted)
  baseUrl     String   @default("") // custom base URL for openai-compatible / custom
  model       String   // model id, e.g. gpt-4o, claude-3-5-sonnet-20241022, gemini-1.5-pro
  isActive    Boolean  @default(true)
  lastTestedAt DateTime?
  lastTestOk  Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agents      Agent[]

  @@index([tenantId])
  @@index([type])
}


// ────────────────────────────────────────────────────────────
// Knowledge Base (RAG source per tenant)
// ────────────────────────────────────────────────────────────
model KnowledgeItem {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // faq | pdf | docx | excel | csv | website | text
  title       String
  content     String   @default("") // raw text / answer
  question    String   @default("") // for FAQ
  chunksJson  String   @default("[]") // JSON: [{text, keywords[]}]
  url         String   @default("")
  status      String   @default("ready") // processing | ready | failed
  size        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
}

// ────────────────────────────────────────────────────────────
// Conversations & Messages
// ────────────────────────────────────────────────────────────
model Conversation {
  id            String   @id @default(cuid())
  tenantId      String
  endUserName   String   @default("مهمان")
  endUserPhone  String   @default("")
  endUserEmail  String   @default("")
  channel       String   @default("widget") // website | widget | instagram | whatsapp | voice
  status        String   @default("ai") // ai | handoff | closed
  confidence    Float    @default(0)
  satisfaction  Int      @default(0) // 0..5
  messageCount  Int      @default(0)
  leadCaptured  Boolean  @default(false)
  operatorId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  operator      User?      @relation("OperatorConversations", fields: [operatorId], references: [id])
  messages      Message[]
  leads         Lead[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | assistant | operator | system
  content        String
  confidence     Float    @default(0)
  tokens         Int      @default(0)
  sourcesJson    String   @default("[]") // knowledge item ids used
  handoff        Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
}

// ────────────────────────────────────────────────────────────
// Leads (per tenant)
// ────────────────────────────────────────────────────────────
model Lead {
  id             String   @id @default(cuid())
  tenantId       String
  conversationId String?
  name           String
  phone          String
  email          String   @default("")
  source         String   @default("chat") // chat | voice | form | referral
  intent         String   @default("inquiry") // inquiry | order | booking | appointment | callback
  status         String   @default("new") // new | contacted | converted | lost
  value          Int      @default(0) // estimated value
  notesJson      String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  bookings       Booking[]

  @@index([tenantId])
  @@index([status])
}

model Booking {
  id             String   @id @default(cuid())
  tenantId       String
  leadId         String?
  conversationId String?
  type           String   // order | reservation | appointment | callback
  payloadJson    String   @default("{}") // booking details
  status         String   @default("pending") // pending | confirmed | cancelled
  scheduledAt    DateTime?
  createdAt      DateTime @default(now())

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead           Lead?    @relation(fields: [leadId], references: [id])

  @@index([tenantId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Subscription, Invoices, Token usage
// ────────────────────────────────────────────────────────────
model Subscription {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  planId        String
  status        String   @default("active") // active | past_due | canceled | trial
  startedAt     DateTime @default(now())
  renewsAt      DateTime
  messageUsage  Int      @default(0)
  conversationUsage Int  @default(0)
  voiceUsage    Int      @default(0)
  tokenUsage    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan          Plan     @relation(fields: [planId], references: [id])

  @@index([tenantId])
}

model Invoice {
  id          String   @id @default(cuid())
  tenantId    String
  planId      String
  amount      Int
  status      String   @default("paid") // paid | pending | failed
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan        Plan     @relation(fields: [planId], references: [id])

  @@index([tenantId])
}

model TokenUsageLog {
  id          String   @id @default(cuid())
  tenantId    String
  tokens      Int
  model       String   @default("glm-4.6")
  feature     String   @default("chat") // chat | embedding | voice
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────
// Referral & Growth Loop
// ────────────────────────────────────────────────────────────
model Referral {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  code        String   @unique
  clicks      Int      @default(0)
  signups     Int      @default(0)
  credits     Int      @default(0) // free credit in Tomans
  commission  Int      @default(0) // earned commission
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([code])
}

model InternalLead {
  id          String   @id @default(cuid())
  tenantId    String
  conversationId String?
  endUserName String
  signal      String   // business_owner_signal
  score       Int      @default(50)
  status      String   @default("new") // new | contacted | converted
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────
// Admin audit / platform config
// ────────────────────────────────────────────────────────────
model PlatformConfig {
  id            String   @id @default(cuid())
  key           String   @unique
  valueJson     String
  updatedAt     DateTime @updatedAt
}
